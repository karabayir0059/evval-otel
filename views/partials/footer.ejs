<!-- FOOTER -->
<footer class="footer">
    <div class="container">
        <div class="footer-grid">
            <div>
                <div class="footer-brand">Evval<span>.</span></div>
                <p class="footer-desc">
                    <%= lang === 'en' 
                        ? 'In the heart of nature, where silence and peace meet. A boutique hotel experience designed to make every moment special.'
                        : 'Doğanın kalbinde, sessizliğin ve huzurun buluştuğu nokta. Her anınızı özel kılmak için tasarlanmış butik otel deneyimi.' %>
                </p>
                <div class="footer-social">
                    <a href="<%= typeof settings !== 'undefined' && settings.social ? settings.social.instagram : '#' %>" aria-label="Instagram">IG</a>
                    <a href="<%= typeof settings !== 'undefined' && settings.social ? settings.social.facebook : '#' %>" aria-label="Facebook">FB</a>
                    <a href="<%= typeof settings !== 'undefined' && settings.social ? settings.social.twitter : '#' %>" aria-label="Twitter">TW</a>
                    <a href="<%= typeof settings !== 'undefined' && settings.social ? settings.social.tripadvisor : '#' %>" aria-label="TripAdvisor">TA</a>
                </div>
            </div>
            <div>
                <h4><%= lang === 'en' ? 'Links' : 'Linkler' %></h4>
                <ul class="footer-links">
                    <li><a href="/<%= lang !== 'tr' ? '?lang=' + lang : '' %>"><%= lang === 'en' ? 'Home' : 'Ana Sayfa' %></a></li>
                    <li><a href="/odalar<%= lang !== 'tr' ? '?lang=' + lang : '' %>"><%= lang === 'en' ? 'Rooms' : 'Odalar' %></a></li>
                    <li><a href="/restoran<%= lang !== 'tr' ? '?lang=' + lang : '' %>"><%= lang === 'en' ? 'Restaurant' : 'Restoran' %></a></li>
                    <li><a href="/spa<%= lang !== 'tr' ? '?lang=' + lang : '' %>">Spa & Wellness</a></li>
                    <li><a href="/galeri<%= lang !== 'tr' ? '?lang=' + lang : '' %>"><%= lang === 'en' ? 'Gallery' : 'Galeri' %></a></li>
                    <li><a href="/iletisim<%= lang !== 'tr' ? '?lang=' + lang : '' %>"><%= lang === 'en' ? 'Contact' : 'İletişim' %></a></li>
                </ul>
            </div>
            <div>
                <h4><%= lang === 'en' ? 'Services' : 'Hizmetler' %></h4>
                <ul class="footer-links">
                    <li><a href="/spa<%= lang !== 'tr' ? '?lang=' + lang : '' %>">Spa & Wellness</a></li>
                    <li><a href="/havuz<%= lang !== 'tr' ? '?lang=' + lang : '' %>"><%= lang === 'en' ? 'Pool' : 'Havuz' %></a></li>
                    <li><a href="#"><%= lang === 'en' ? 'Transfer' : 'Transfer' %></a></li>
                    <li><a href="#"><%= lang === 'en' ? 'Tours' : 'Özel Turlar' %></a></li>
                    <li><a href="/hizmetler<%= lang !== 'tr' ? '?lang=' + lang : '' %>"><%= lang === 'en' ? 'All Services' : 'Tüm Hizmetler' %></a></li>
                </ul>
            </div>
            <div>
                <h4><%= lang === 'en' ? 'Contact' : 'İletişim' %></h4>
                <div class="footer-contact-item">
                    <span>📍</span>
                    <span><%= typeof settings !== 'undefined' && settings.contact ? settings.contact.address : 'Örnek Mahallesi, Doğa Caddesi No:1' %></span>
                </div>
                <div class="footer-contact-item">
                    <span>📞</span>
                    <span><%= typeof settings !== 'undefined' && settings.contact ? settings.contact.phone : '+90 (555) 123 45 67' %></span>
                </div>
                <div class="footer-contact-item">
                    <span>✉</span>
                    <span><%= typeof settings !== 'undefined' && settings.contact ? settings.contact.email : 'info@evvalotel.com' %></span>
                </div>
                <div class="footer-contact-item">
                    <span>🕐</span>
                    <span><%= typeof settings !== 'undefined' && settings.working_hours ? (settings.working_hours[lang] || settings.working_hours.tr) : 'Check-in: 14:00 | Check-out: 12:00' %></span>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <span>© 2026 Evval Otel. <%= lang === 'en' ? 'All rights reserved.' : 'Tüm hakları saklıdır.' %></span>
            <span><%= lang === 'en' ? 'Premium Boutique Hotel Experience' : 'Premium Butik Otel Deneyimi' %></span>
        </div>
    </div>
</footer>

<!-- SCRIPTS -->
<script src="/js/main.js"></script>
</body>
</html>
