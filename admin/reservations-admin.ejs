<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rezervasyonlar - Evval Hotel Admin</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="admin-body">
    <div class="admin-sidebar">
      <div class="admin-sidebar-logo">Evval<span>.</span></div>
      <nav class="admin-sidebar-nav">
        <a href="/admin/dashboard" class="<%= page === 'dashboard' ? 'active' : '' %>">📊 Dashboard</a>
        <a href="/admin/pages" class="<%= page === 'pages' ? 'active' : '' %>">📝 Sayfalar</a>
        <a href="/admin/rooms" class="<%= page === 'rooms' ? 'active' : '' %>">🛏 Odalar</a>
        <a href="/admin/menu" class="<%= page === 'menu' ? 'active' : '' %>">🍽 Menü</a>
        <a href="/admin/gallery" class="<%= page === 'gallery' ? 'active' : '' %>">🖼 Galeri</a>
        <a href="/admin/reviews" class="<%= page === 'reviews' ? 'active' : '' %>">⭐ Yorumlar</a>
        <a href="/admin/reservations" class="<%= page === 'reservations' ? 'active' : '' %>">📋 Rezervasyonlar</a>
        <a href="/admin/settings" class="<%= page === 'settings' ? 'active' : '' %>">⚙ Ayarlar</a>
      </nav>
    </div>

    <div class="admin-main">
      <div class="admin-header">
        <h1>Rezervasyonlar</h1>
        <button id="logoutBtn" class="admin-btn">Çıkış</button>
      </div>

      <table class="admin-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>İsim</th>
            <th>E-posta</th>
            <th>Telefon</th>
            <th>Giriş</th>
            <th>Çıkış</th>
            <th>Oda</th>
            <th>Misafir</th>
            <th>Durum</th>
          </tr>
        </thead>
        <tbody>
          <% if (reservations && reservations.length > 0) { %>
            <% reservations.forEach(function(r) { %>
              <tr>
                <td><%= r.id %></td>
                <td><%= r.name %></td>
                <td><%= r.email %></td>
                <td><%= r.phone %></td>
                <td><%= r.checkIn %></td>
                <td><%= r.checkOut %></td>
                <td><%= r.room %></td>
                <td><%= r.guests %></td>
                <td>
                  <% if (r.status === 'confirmed') { %>
                    <span style="color:green;font-weight:bold;">Onaylı</span>
                  <% } else if (r.status === 'pending') { %>
                    <span style="color:orange;font-weight:bold;">Bekliyor</span>
                  <% } else if (r.status === 'cancelled') { %>
                    <span style="color:red;font-weight:bold;">İptal</span>
                  <% } else { %>
                    <span><%= r.status %></span>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="9" style="text-align:center;">Henüz rezervasyon yok</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <script src="/js/admin.js"></script>
</body>
</html>
